APP_NAME=The On Looker API
APP_VERSION=0.1.0
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
AUTO_INITIALIZE_DB=true
DATABASE_URL=postgresql+asyncpg://onlooker:onlooker@localhost:5432/onlooker
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_MINUTES=20160
JWT_ISSUER=the-on-looker
REGISTRATION_OTP_EXPIRE_MINUTES=10
REGISTRATION_OTP_MAX_ATTEMPTS=5
LOGIN_OTP_EXPIRE_MINUTES=5

# SMTP (required in production for OTP delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
# Optional: internal copy for OTP issuance monitoring
OTP_ADMIN_NOTIFICATION_EMAIL=

SSO_ALLOWED_DOMAINS=example.com,company.com

# Phase 7 NVIDIA copilot key
NVIDIA_API_KEY=

# Phase 7 PayPal billing keys
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_SECRET=

# Reliability tuning
REPORT_CACHE_TTL_SECONDS=120
PDF_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_BASE_DELAY_MS=200
INTELLIGENCE_RATE_LIMIT_PER_MINUTE=120
INTELLIGENCE_RETRY_ATTEMPTS=3
INTELLIGENCE_RETRY_BASE_DELAY_MS=300

# IoT connector endpoints and secrets
MQTT_BROKER_URL=
MQTT_TOPIC=
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS_ENABLED=false

KAFKA_BOOTSTRAP_SERVERS=
KAFKA_TOPIC=
KAFKA_GROUP_ID=onlooker-phase9
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

DEVICE_GATEWAY_URL=
DEVICE_GATEWAY_API_KEY=
DEVICE_GATEWAY_HMAC_SECRET=

# Signed satellite provider client
SATELLITE_PROVIDER_BASE_URL=
SATELLITE_PROVIDER_API_KEY=
SATELLITE_PROVIDER_HMAC_SECRET=
SATELLITE_PROVIDER_TIMEOUT_SECONDS=10
SATELLITE_PROVIDER_MOCK_MODE=true

EXPORT_ARTIFACTS_DIR=artifacts/visualization_exports
EXPORT_MP4_DURATION_SECONDS=8
