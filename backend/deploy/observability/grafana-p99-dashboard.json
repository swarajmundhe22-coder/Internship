{
  "title": "OnLookers P99 Latency",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "P99 Latency by Endpoint (10s)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, path) (rate(onlooker_http_request_latency_seconds_bucket[10s])))",
          "legendFormat": "{{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "orange", "value": 0.15},
              {"color": "red", "value": 0.2}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "P95/P50 Latency - /simulation/simulate",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(onlooker_http_request_latency_seconds_bucket{path=\"/simulation/simulate\"}[10s])))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(onlooker_http_request_latency_seconds_bucket{path=\"/simulation/simulate\"}[10s])))",
          "legendFormat": "P50"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "5xx Error Ratio (1h)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(onlooker_http_requests_total{status_code=~\"5..\"}[1h])) / clamp_min(sum(rate(onlooker_http_requests_total[1h])), 1)",
          "legendFormat": "5xx ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    }
  ]
}
